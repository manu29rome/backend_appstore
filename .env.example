# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# En Railway: usar las variables del plugin PostgreSQL
DB_HOST=                          # ej: containers-us-west-xxx.railway.app
DB_PORT=5432
DB_NAME=SuitexTechDB
DB_USER=postgres
DB_PASSWORD=                      # contraseña del plugin PostgreSQL de Railway

# ── JWT (genera con: openssl rand -hex 64) ───────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://tu-frontend.up.railway.app

# ── Email (opcional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
